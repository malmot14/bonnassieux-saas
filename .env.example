# ──────────────────────────────────────────────────────────────────
# Bonnassieux CRM — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# ──────────────────────────────────────────────────────────────────

# Base de données Supabase (PostgreSQL)
# Récupérer depuis : Supabase → Settings → Database → Connection string → URI
# Utiliser le mode "Transaction" (port 6543) pour la production
DATABASE_URL=postgresql://postgres.ttwpvcvlnzqkpootcttt:[MOT_DE_PASSE]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# Clé secrète JWT (minimum 32 caractères aléatoires)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=changez_cette_valeur_par_une_chaine_aleatoire_longue

# Google Maps API Key (https://console.cloud.google.com)
# Activer : Maps JavaScript API + Geocoding API
VITE_GOOGLE_MAPS_API_KEY=AIzaSy...

# Compte admin créé automatiquement au 1er démarrage
ADMIN_EMAIL=admin@bonnassieux.fr
ADMIN_PASSWORD=mot_de_passe_fort

# Environnement
NODE_ENV=production
PORT=3000
